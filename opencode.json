{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "autocoder",
  "instructions": [
    "Sanitized public contract. private repository only for operational config."
  ],
  "agent": {
    "autocoder": {
      "description": "Primary autocode execution path.",
      "mode": "primary",
      "maxSteps": 6
    },
    "general": {
      "description": "General-purpose fallback agent.",
      "mode": "primary",
      "maxSteps": 50
    },
    "explore": {
      "description": "Repository exploration agent.",
      "mode": "primary"
    },
    "reviewer": {
      "description": "Technical review agent.",
      "mode": "primary"
    },
    "orchestrator": {
      "description": "Swarm orchestration agent.",
      "mode": "primary"
    }
  },
  "command": {
    "autocode": {
      "template": "{{args}}",
      "description": "Autocode command. private repository only for full operational prompts.",
      "agent": "autocoder"
    },
    "analyze": {
      "template": "{{args}}",
      "description": "Analyze command.",
      "agent": "explore"
    },
    "review": {
      "template": "{{args}}",
      "description": "Review command.",
      "agent": "reviewer"
    },
    "ship": {
      "template": "{{args}}",
      "description": "Ship command.",
      "agent": "orchestrator"
    }
  }
}
