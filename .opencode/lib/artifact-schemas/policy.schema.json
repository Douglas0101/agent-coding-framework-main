{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "policy.schema.json",
  "title": "PolicyBundle",
  "description": "Executable policy constraints compiled from domain specs. Enforced at spec-time, pre-flight, in-flight and post-flight.",
  "type": "object",
  "required": ["policy_bundle", "version", "rules"],
  "additionalProperties": false,
  "properties": {
    "policy_bundle": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "action"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "description": { "type": "string" },
          "when": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "array",
                "items": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
              },
              "change_surface": {
                "type": "array",
                "items": { "type": "string", "enum": ["code", "api", "data", "auth", "runtime"] }
              },
              "node_type": {
                "type": "array",
                "items": { "type": "string" }
              },
              "change_kind": {
                "type": "array",
                "items": { "type": "string" }
              },
              "paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "action": {
            "type": "string",
            "enum": ["require_field", "require", "require_evidence", "require_approval", "block_direct_write"]
          },
          "field": { "type": "string" },
          "constraint": { "type": "object" },
          "evidence_types": { "type": "array", "items": { "type": "string" } },
          "approvers": { "type": "array", "items": { "type": "string" } },
          "error": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
