{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "behavior.schema.json",
  "title": "BehaviorSpec",
  "description": "Specifies valid states and permitted transitions as a typed state machine.",
  "type": "object",
  "required": ["behavior_id", "version", "capability_ref", "states", "initial_state", "terminal_states", "transitions"],
  "additionalProperties": false,
  "properties": {
    "behavior_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "capability_ref": {
      "type": "string",
      "pattern": "^capability\\.[a-z0-9][a-z0-9._-]*$"
    },
    "description": { "type": "string" },
    "states": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "initial_state": { "type": "string" },
    "terminal_states": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "guard": { "type": "string" },
          "action": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 0
    }
  }
}
