{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "capability.schema.json",
  "title": "CapabilitySpec",
  "description": "Defines what the platform must be capable of doing, independent of implementation.",
  "type": "object",
  "required": ["spec_id", "version", "status", "domain", "objective", "inputs", "outputs", "invariants"],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^capability\\.[a-z0-9][a-z0-9._-]*$",
      "description": "Unique identifier, must start with 'capability.'"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "approved", "deprecated"]
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "non_functional": {
      "type": "object",
      "properties": {
        "latency_p95_ms": { "type": "number", "minimum": 0 },
        "availability_slo": { "type": "number", "minimum": 0, "maximum": 100 },
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 10 }
      },
      "additionalProperties": false
    },
    "traceability": {
      "type": "object",
      "properties": {
        "owner_technical": { "type": "string" },
        "owner_domain": { "type": "string" },
        "requirement_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
