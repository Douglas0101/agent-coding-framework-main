{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run-manifest.schema.json",
  "title": "RunManifest",
  "description": "Complete manifest of a swarm run, including spec links, agents activated, artifacts produced and traceability coverage.",
  "type": "object",
  "required": ["schema_version", "artifact_type", "run_id", "spec_id", "spec_version", "timestamp", "status", "agents_activated", "artifacts_produced"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "artifact_type": { "type": "string", "enum": ["run-manifest"] },
    "run_id": { "type": "string" },
    "spec_id": { "type": "string" },
    "spec_version": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["running", "completed", "failed", "cancelled", "blocked"] },
    "budget": {
      "type": "object",
      "properties": {
        "max_tokens": { "type": "integer" },
        "used_tokens": { "type": "integer" },
        "max_cost_usd": { "type": "number" },
        "used_cost_usd": { "type": "number" }
      }
    },
    "agents_activated": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "verdict"],
        "properties": {
          "agent": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "pass_with_notes", "fail", "skipped"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "duration_ms": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "artifacts_produced": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "path"],
        "properties": {
          "artifact_type": { "type": "string" },
          "path": { "type": "string" },
          "checksum": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "trace_links": {
      "type": "object",
      "properties": {
        "requirements": { "type": "array", "items": { "type": "string" } },
        "code_refs": { "type": "array", "items": { "type": "string" } },
        "test_cases": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "traceability_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "remaining_risks": { "type": "array", "items": { "type": "string" } },
    "next_steps": { "type": "array", "items": { "type": "string" } }
  }
}
