{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "traceability-link.schema.json",
  "title": "TraceabilityLink",
  "description": "Bidirectional traceability from requirements to runtime: requirement -> spec -> DAG node -> code -> test -> runtime trace.",
  "type": "object",
  "required": ["link_id", "schema_version", "spec_id", "spec_version", "run_id", "timestamp", "links"],
  "additionalProperties": false,
  "properties": {
    "link_id": { "type": "string" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "spec_id": { "type": "string" },
    "spec_version": { "type": "string" },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "links": {
      "type": "object",
      "properties": {
        "requirements": { "type": "array", "items": { "type": "string" } },
        "specs": { "type": "array", "items": { "type": "string" } },
        "dag_nodes": { "type": "array", "items": { "type": "string" } },
        "code_refs": { "type": "array", "items": { "type": "string" } },
        "test_cases": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "runtime_trace_ids": { "type": "array", "items": { "type": "string" } },
        "owner_technical": { "type": "string" },
        "owner_domain": { "type": "string" }
      },
      "additionalProperties": false
    },
    "missing_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity"],
        "properties": {
          "type": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "error", "blocking"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
