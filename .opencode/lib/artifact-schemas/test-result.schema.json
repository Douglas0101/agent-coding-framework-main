{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-result.schema.json",
  "title": "TestResult",
  "description": "Structured output from the tester agent with test execution summary.",
  "type": "object",
  "required": ["schema_version", "artifact_type", "producer_agent", "spec_id", "spec_version", "run_id", "timestamp", "risk_level", "verdict", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "artifact_type": { "type": "string", "enum": ["test-result"] },
    "producer_agent": { "type": "string", "enum": ["tester"] },
    "spec_id": { "type": "string" },
    "spec_version": { "type": "string" },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "verdict": { "type": "string", "enum": ["pass", "partial", "fail"] },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_name", "reason"],
        "properties": {
          "test_name": { "type": "string" },
          "reason": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
        },
        "additionalProperties": false
      }
    },
    "coverage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "harness_used": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "trace_links": { "type": "array", "items": { "type": "string" } }
  }
}
