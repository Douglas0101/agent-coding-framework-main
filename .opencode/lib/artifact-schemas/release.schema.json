{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "release.schema.json",
  "title": "ReleaseSpec",
  "description": "Defines rollout strategy, stage gates, and rollback conditions linked to SLO and conformance specs.",
  "type": "object",
  "required": ["release_id", "version", "capability_ref", "strategy", "stages", "rollback", "gates"],
  "additionalProperties": false,
  "properties": {
    "release_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "capability_ref": { "type": "string" },
    "slo_ref": { "type": "string" },
    "description": { "type": "string" },
    "strategy": {
      "type": "string",
      "enum": ["canary", "blue-green", "rolling", "direct"]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "percentage", "bake_minutes"],
        "properties": {
          "name": { "type": "string" },
          "percentage": { "type": "integer", "minimum": 1, "maximum": 100 },
          "bake_minutes": { "type": "integer", "minimum": 0 },
          "validation": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "rollback": {
      "type": "object",
      "required": ["trigger_conditions", "max_rollback_minutes"],
      "properties": {
        "trigger_conditions": { "type": "array", "items": { "type": "string" } },
        "max_rollback_minutes": { "type": "integer", "minimum": 1 },
        "requires_evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "properties": {
        "pre_deploy": { "type": "array", "items": { "type": "string" } },
        "post_deploy": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
