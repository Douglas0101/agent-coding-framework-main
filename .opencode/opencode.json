{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "autocoder",
  "agent": {
    "autocoder": {
      "description": "Primary autocode execution path.",
      "mode": "primary",
      "maxSteps": 6,
      "mode_contract": ".internal/specs/modes/autocoder.yaml"
    },
    "general": {
      "description": "General-purpose fallback agent.",
      "mode": "primary",
      "maxSteps": 50
    },
    "explore": {
      "description": "Repository exploration agent.",
      "mode": "primary",
      "mode_contract": ".internal/specs/modes/explore.yaml"
    },
    "reviewer": {
      "description": "Technical review agent.",
      "mode": "primary",
      "mode_contract": ".internal/specs/modes/reviewer.yaml"
    },
    "orchestrator": {
      "description": "Swarm orchestration agent.",
      "mode": "primary",
      "mode_contract": ".internal/specs/modes/orchestrator.yaml"
    }
  },
  "command": {
    "autocode": {
      "template": "{{args}}",
      "description": "Autocode command.",
      "agent": "autocoder"
    },
    "analyze": {
      "template": "{{args}}",
      "description": "Analyze command.",
      "agent": "explore"
    },
    "review": {
      "template": "{{args}}",
      "description": "Review command.",
      "agent": "reviewer"
    },
    "ship": {
      "template": "{{args}}",
      "description": "Ship command.",
      "agent": "orchestrator"
    }
  }
}
