# OS and editor cruft
.DS_Store
Thumbs.db
*.log

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# JetBrains
.idea/

# OpenCode: default deny, explicit allow for public contract files
.opencode/*
!.opencode/opencode.json
!.opencode/specs/
!.opencode/specs/README.md
!.opencode/specs/*.sanitized.json
!.opencode/manifests/
!.opencode/manifests/README.md
!.opencode/manifests/sanitized/
!.opencode/manifests/sanitized/*.json

# OpenCode runtime/sensitive subtrees
.opencode/node_modules/
.opencode/memory/
.opencode/evidence/
.opencode/context/
.opencode/tmp/
.opencode/artifacts/

# Internal operational directories must stay out of the public repository
.agent/
.codex/
