{
  "manifest_version": "1.0.0",
  "pack_id": "pack-ml-ai",
  "name": "ML/AI Domain Pack",
  "version": "1.0.0",
  "domain": "ml-ai",
  "description": "Optional domain pack for machine learning and AI workflows including training, optimization, experiment tracking, and agentic RAG",
  "core_version": ">=1.0.0",
  "status": "experimental",
  "type": "vertical",
  "metadata": {
    "author": "Framework Team",
    "license": "MIT",
    "repository": "",
    "created": "2026-04-03",
    "updated": "2026-04-03"
  },
  "dependencies": {
    "required": ["pack-software-engineering"],
    "optional": []
  },
  "capabilities": [
    "model_training",
    "experiment_tracking",
    "model_optimization",
    "ml_pipeline",
    "hyperparameter_tuning",
    "agentic_rag",
    "model_lineage",
    "data_contracts"
  ],
  "agents": [
    {
      "name": "ml-researcher",
      "role": "research",
      "capabilities": ["paper_search", "technique_analysis", "benchmark_comparison"]
    },
    {
      "name": "ml-engineer",
      "role": "development",
      "capabilities": ["model_architecture", "data_preprocessing", "training_loop", "evaluation"]
    },
    {
      "name": "ml-optimizer",
      "role": "optimization",
      "capabilities": ["hyperparameter_search", "quantization", "pruning", "distillation"]
    }
  ],
  "gates": [
    {
      "name": "ml_validation_gate",
      "type": "validation",
      "config": {
        "strict_mode": true,
        "fail_fast": true
      }
    }
  ],
  "contracts": {
    "primary": "contract.yaml",
    "schemas": ["agents", "gates"]
  },
  "tags": ["domain", "ml", "ai", "optional", "experimental"],
  "compatibility": {
    "core_protocols": ["Verifier", "Synthesizer", "Handoff"],
    "protocol_version": "1.0.0"
  }
}