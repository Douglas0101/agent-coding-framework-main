  "operational_skills": [
    "backend-reliability",
    "data-structures-rigor",
    "dba-governance",
    "refactor-patterns",
    "test-coverage"
  ],
  "gates": [
    {
      "name": "code_quality_gate",
      "type": "quality",
      "config": {
        "strict_mode": true,
        "fail_fast": true
      }
    }
  ],
  "contracts": {
    "primary": "contract.yaml",
    "schemas": ["agents", "gates"]
  },
  "tags": ["functional", "software", "development", "default"],
  "compatibility": {
    "core_protocols": ["Verifier", "Synthesizer", "Handoff"],
    "protocol_version": "1.0.0"
  }
