{
  "manifest_version": "1.0.0",
  "pack_id": "pack-software-engineering",
  "name": "Software Engineering Pack",
  "version": "1.0.0",
  "domain": "software-engineering",
  "description": "Default functional pack providing software engineering workflow capabilities including code analysis, refactoring, testing, and review",
  "core_version": ">=1.0.0",
  "status": "active",
  "type": "functional",
  "metadata": {
    "author": "Framework Team",
    "license": "MIT",
    "repository": "",
    "created": "2026-04-03",
    "updated": "2026-04-03"
  },
  "dependencies": {
    "required": [],
    "optional": []
  },
  "capabilities": [
    "code_analysis",
    "code_generation",
    "refactoring",
    "test_generation",
    "code_review",
    "vulnerability_detection",
    "documentation_generation",
    "dependency_management",
    "backend_reliability",
    "data_structures_rigor",
    "dba_governance",
    "design_patterns",
    "test_coverage"
